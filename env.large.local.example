# Local LARGE stack → copied to .env.pkg_large by scripts/up_pkg_large.sh
# Published ports avoid collision with demo stack (5432 / 8000 / 4173).

PKG_LARGE_HOST_POSTGRES_PORT=5433
PKG_LARGE_HOST_BACKEND_PORT=8001
PKG_LARGE_HOST_FRONTEND_PORT=4174

SECRET_KEY=pkg-large-local-placeholder-REPLACE-OR-RUN-up_pkg_large-sh
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:4174,http://127.0.0.1:4174
CSRF_TRUSTED_ORIGINS=http://localhost:4174,http://127.0.0.1:4174
SECURE_SSL_REDIRECT=False

POSTGRES_DB=weightlifting_db
POSTGRES_USER=weightlifting_user
POSTGRES_PASSWORD=pkg_large_local_db_pw_change_me
DATABASE_URL=postgresql://weightlifting_user:pkg_large_local_db_pw_change_me@postgres:5432/weightlifting_db

# Must match PKG_LARGE_HOST_BACKEND_PORT (browser calls API on host).
VITE_API_BASE_URL=http://localhost:8001

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=115 Weightlifting <noreply@example.invalid>
PASSWORD_RESET_FRONTEND_URL=http://localhost:4174/reset-password
PASSWORD_RESET_DEBUG_RESPONSE=True

# Baseline LARGE roster: 1 GM + 4 AGM heads + 8 line coaches + 32 athletes (canonical naming).
SEED_DEMO=true
UAT3_DEMO_SCENARIO=pkg_large
DEMO_PASSWORD=Passw0rd!123
DEMO_EMAIL_DOMAIN=example.invalid

COACH_SIGNUP_CODE=docker-uat-coach
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
THROTTLE_LOGIN=30/min
THROTTLE_REGISTER=10/min
