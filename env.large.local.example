# Local / bare-metal LARGE-shaped stack — copy to .env.pkg_large (see scripts/up_pkg_large.sh).
# Uses HTTP on localhost (no TLS terminator). Replace SECRET_KEY and DB password before any exposure.

SECRET_KEY=pkg-large-local-placeholder-REPLACE-OR-RUN-up_pkg_large-sh
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
CSRF_TRUSTED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
SECURE_SSL_REDIRECT=False

POSTGRES_DB=weightlifting_db
POSTGRES_USER=weightlifting_user
POSTGRES_PASSWORD=pkg_large_local_db_pw_change_me
DATABASE_URL=postgresql://weightlifting_user:pkg_large_local_db_pw_change_me@postgres:5432/weightlifting_db

VITE_API_BASE_URL=http://localhost:8000

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=115 Weightlifting <noreply@example.invalid>
PASSWORD_RESET_FRONTEND_URL=http://localhost:4173/reset-password
PASSWORD_RESET_DEBUG_RESPONSE=True

SEED_DEMO=false
DEMO_PASSWORD=
DEMO_EMAIL_DOMAIN=

COACH_SIGNUP_CODE=docker-uat-coach
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
THROTTLE_LOGIN=30/min
THROTTLE_REGISTER=10/min
