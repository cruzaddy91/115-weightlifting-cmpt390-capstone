# Large-business / production-shaped Compose environment (committed template).
# Intended for packaging branch pkg_large (see docs/DEPLOYMENT_LARGE.md).
# Tier branches pkg_medium / pkg_small will get their own env templates later.
#
# For localhost LARGE bootstrap without overwriting demo `.env`, prefer:
#   env.large.local.example  →  .env.pkg_large  +  scripts/up_pkg_large.sh
#
# Copy this file to `.env.pkg_large` (production hosts) when using three-file merge:
#   docker compose --env-file .env.pkg_large \
#     -f docker-compose.yml -f docker-compose.large.yml -f docker-compose.pkg_large.yml up --build
#
# Django refuses to start with DEBUG=False if SECRET_KEY is still the insecure
# default — use a long random value (see Django docs).

# Django
SECRET_KEY=replace-with-a-long-random-secret-min-fifty-chars
DEBUG=False
ALLOWED_HOSTS=api.example.invalid,backend
CORS_ALLOWED_ORIGINS=https://app.example.invalid
CSRF_TRUSTED_ORIGINS=https://app.example.invalid

# Behind a TLS-terminating proxy that sets X-Forwarded-Proto: https — leave True.
# For local HTTP-only smoke tests behind LARGE compose, set SECURE_SSL_REDIRECT=False.
SECURE_SSL_REDIRECT=True

# PostgreSQL — point at managed DB or the Compose service hostname `postgres`
POSTGRES_DB=weightlifting_db
POSTGRES_USER=weightlifting_user
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://weightlifting_user:replace-with-strong-db-password@postgres:5432/weightlifting_db

# Frontend build — use public API URL that browsers will call
VITE_API_BASE_URL=https://api.example.invalid

# Email — use a real backend for password reset (not console)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.invalid
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=115 Weightlifting <noreply@example.invalid>
PASSWORD_RESET_FRONTEND_URL=https://app.example.invalid/reset-password
PASSWORD_RESET_DEBUG_RESPONSE=False

# No demo seed on LARGE-shaped deployments
SEED_DEMO=false

# Optional: unset or empty — demo provisioning only
DEMO_PASSWORD=
DEMO_EMAIL_DOMAIN=

# Optional signup / rate limits
COACH_SIGNUP_CODE=
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
THROTTLE_LOGIN=30/min
THROTTLE_REGISTER=10/min

# Optional: scale Gunicorn (backend Dockerfile defaults apply if unset)
# GUNICORN_WORKERS=4
