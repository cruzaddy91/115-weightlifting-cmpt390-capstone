# Copy to .env before running Docker Compose.

# Django
SECRET_KEY=change-this-to-a-long-random-secret-for-real-deployment
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
CSRF_TRUSTED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
SECURE_SSL_REDIRECT=False

# PostgreSQL used by docker-compose.yml
POSTGRES_DB=weightlifting_db
POSTGRES_USER=weightlifting_user
POSTGRES_PASSWORD=weightlifting_password
DATABASE_URL=postgresql://weightlifting_user:weightlifting_password@postgres:5432/weightlifting_db

# Frontend build/runtime
VITE_API_BASE_URL=http://localhost:8000

# Demo data for professor/local review
SEED_DEMO=true
DEMO_PASSWORD=Passw0rd!123
